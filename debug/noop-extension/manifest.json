{
  "manifest_version": 3,
  "name": "ChatGPT Font No-op Debug",
  "description": "Debug extension that loads but does not modify ChatGPT.",
  "version": "1.0.0",
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
